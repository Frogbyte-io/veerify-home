---
import Layout from './Layout.astro'
import TheNavbar from '../components/TheNavbar.astro'
import TheFooter from '../components/TheFooter.astro'
import { getDateLocale, getDictionary, withLocale, type Locale, type SiteDictionary } from '../i18n/site'
import { buildArticleSchema, buildBreadcrumbSchema, getCanonicalPath } from '../lib/seo'

interface Props {
  locale: Locale
  t: SiteDictionary['blog']
  title: string
  description: string
  pubDate: Date
  author: string
  tags: string[]
  updatedDate?: Date
}

const { locale, t, title, description, pubDate, author, tags, updatedDate } = Astro.props

const formattedPubDate = new Intl.DateTimeFormat(getDateLocale(locale), {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate)

const formattedUpdatedDate = updatedDate
  ? new Intl.DateTimeFormat(getDateLocale(locale), {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(updatedDate)
  : null

const dict = getDictionary(locale)
const blogHref = withLocale(locale, '/blog')
const articlePath = getCanonicalPath(Astro.url.pathname, locale, true)
const articleSchema = buildArticleSchema({
  headline: title,
  description,
  path: articlePath,
  locale,
  datePublished: pubDate,
  dateModified: updatedDate,
  author,
  keywords: tags,
})
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', path: withLocale(locale) },
  { name: 'Blog', path: blogHref },
  { name: title, path: articlePath },
])
---

<Layout
  locale={locale}
  title={`${title} - ${t.pageTitleSuffix}`}
  description={description}
  ogDescription={description}
  type="article"
  article={{
    publishedTime: pubDate,
    modifiedTime: updatedDate,
    author,
    tags,
  }}
  jsonLd={[breadcrumbSchema, articleSchema]}
>
  <TheNavbar locale={locale} t={dict.navbar} />

  <main class="mx-auto max-w-3xl px-6 py-16 lg:px-8 lg:py-24">
    <a
      href={blogHref}
      class="mb-10 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      {t.backToBlog}
    </a>

    <header class="mb-12">
      {tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="font-display text-4xl font-bold leading-tight tracking-tight lg:text-5xl">
        {title}
      </h1>

      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
        <span>{author}</span>
        <span class="h-1 w-1 rounded-full bg-border"></span>
        <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        {formattedUpdatedDate && (
          <>
            <span class="h-1 w-1 rounded-full bg-border"></span>
            <span>{t.updatedPrefix} {formattedUpdatedDate}</span>
          </>
        )}
      </div>
    </header>

    <article class="prose prose-slate dark:prose-invert max-w-none
      prose-headings:font-display prose-headings:tracking-tight
      prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-12 prose-h2:mb-4
      prose-h3:text-lg prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3
      prose-p:leading-relaxed prose-p:text-muted-foreground
      prose-strong:text-foreground prose-strong:font-semibold
      prose-a:text-primary prose-a:no-underline hover:prose-a:underline
      prose-code:bg-secondary prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
      prose-blockquote:border-l-primary prose-blockquote:text-muted-foreground
      prose-ul:text-muted-foreground prose-ol:text-muted-foreground
      prose-li:marker:text-primary
    ">
      <slot />
    </article>

    <div class="mt-16 rounded-2xl border border-border/60 bg-card p-8 text-center">
      <p class="mb-2 text-xs font-semibold uppercase tracking-[0.15em] text-primary">{t.tryVeerify}</p>
      <h2 class="font-display mb-3 text-2xl font-bold">{t.bottomTitle}</h2>
      <p class="mb-6 text-sm text-muted-foreground">{t.bottomDescription}</p>
      <a
        href="https://app.veerify.io/get-started"
        class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-primary px-6 text-sm font-semibold text-primary-foreground shadow-md shadow-primary/20 transition-all hover:opacity-90"
      >
        {t.bottomCta}
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </main>

  <TheFooter locale={locale} t={dict.footer} />
</Layout>
