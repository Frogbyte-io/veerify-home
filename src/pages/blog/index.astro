---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import TheNavbar from '../../components/TheNavbar.astro'
import TheFooter from '../../components/TheFooter.astro'
import { defaultLocale, getDateLocale, getDictionary, withLocale } from '../../i18n/site'

const locale = defaultLocale
const dict = getDictionary(locale)

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

function formatDate(date: Date) {
  return new Intl.DateTimeFormat(getDateLocale(locale), {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date)
}

const homeHref = withLocale(locale)
---

<Layout
  locale={locale}
  title={dict.blog.title}
  description={dict.blog.description}
>
  <TheNavbar locale={locale} t={dict.navbar} />

  <main class="mx-auto max-w-7xl px-6 py-16 lg:px-8 lg:py-24">
    <div class="mb-16">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">{dict.blog.sectionLabel}</p>
      <h1 class="font-display text-4xl font-bold tracking-tight lg:text-5xl">
        {dict.blog.headingTop}<br />
        <em class="italic text-primary">{dict.blog.headingAccent}</em>
      </h1>
      <p class="mt-4 max-w-lg text-lg leading-relaxed text-muted-foreground">{dict.blog.intro}</p>
    </div>

    {posts.length === 0 ? (
      <div class="rounded-2xl border border-border/50 bg-card p-16 text-center">
        <p class="text-muted-foreground">{dict.blog.noPosts}</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map(post => (
          <a
            href={`${homeHref}/blog/${post.slug}`}
            class="post-card group flex flex-col rounded-2xl border border-border/60 bg-card p-6 transition-all hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-0.5"
          >
            {post.data.tags.length > 0 && (
              <div class="mb-4 flex flex-wrap gap-1.5">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-[10px] font-medium text-primary">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <h2 class="font-display mb-3 text-xl font-bold leading-snug tracking-tight transition-colors group-hover:text-primary">
              {post.data.title}
            </h2>

            <p class="mb-6 line-clamp-3 flex-1 text-sm leading-relaxed text-muted-foreground">
              {post.data.description}
            </p>

            <div class="flex items-center justify-between text-xs text-muted-foreground">
              <span>{post.data.author}</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>

  <TheFooter locale={locale} t={dict.footer} />
</Layout>

<style>
  .post-card {
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }
</style>
