---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import TheNavbar from '../../components/TheNavbar.astro'
import TheFooter from '../../components/TheFooter.astro'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date)
}
---

<Layout
  title="Blog — Veerify"
  description="Insights on feedback management, product development, and building user-centric software."
>
  <TheNavbar />

  <main class="mx-auto max-w-7xl px-6 py-16 lg:px-8 lg:py-24">

    <!-- Page header -->
    <div class="mb-16">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">Blog</p>
      <h1 class="font-display text-4xl font-bold tracking-tight lg:text-5xl">
        Thoughts on building<br />
        <em class="italic text-primary">better products.</em>
      </h1>
      <p class="mt-4 max-w-lg text-lg leading-relaxed text-muted-foreground">
        Insights on feedback management, product development, and what it takes to build software users actually love.
      </p>
    </div>

    <!-- Posts grid -->
    {posts.length === 0 ? (
      <div class="rounded-2xl border border-border/50 bg-card p-16 text-center">
        <p class="text-muted-foreground">No posts published yet. Check back soon.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map(post => (
          <a
            href={`/blog/${post.slug}`}
            class="post-card group flex flex-col rounded-2xl border border-border/60 bg-card p-6 transition-all hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-0.5"
          >
            <!-- Tags -->
            {post.data.tags.length > 0 && (
              <div class="mb-4 flex flex-wrap gap-1.5">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-[10px] font-medium text-primary">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <!-- Title -->
            <h2 class="font-display mb-3 text-xl font-bold leading-snug tracking-tight group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>

            <!-- Excerpt -->
            <p class="mb-6 flex-1 text-sm leading-relaxed text-muted-foreground line-clamp-3">
              {post.data.description}
            </p>

            <!-- Meta -->
            <div class="flex items-center justify-between text-xs text-muted-foreground">
              <span>{post.data.author}</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>

  <TheFooter />
</Layout>

<style>
  .post-card {
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }
</style>
