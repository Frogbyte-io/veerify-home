---
import Layout from '../../layouts/Layout.astro'
import TheNavbar from '../../components/TheNavbar.astro'
import TheFooter from '../../components/TheFooter.astro'
import { comparisonEntries, getComparisonEntry } from '../../lib/compare'
import { buildBreadcrumbSchema, buildFaqSchema } from '../../lib/seo'
import { defaultLocale, getDictionary } from '../../i18n/site'

export function getStaticPaths() {
  return comparisonEntries.map((entry) => ({
    params: { slug: entry.slug },
  }))
}

const { slug } = Astro.params
const entry = slug ? getComparisonEntry(slug) : undefined

if (!entry) {
  throw new Error(`Unknown comparison page: ${slug}`)
}

const locale = defaultLocale
const dict = getDictionary(locale)
const relatedEntries = comparisonEntries.filter((candidate) => candidate.slug !== entry.slug).slice(0, 3)
const jsonLd = [
  buildBreadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Compare', path: '/compare' },
    { name: `Veerify vs ${entry.competitor}`, path: `/compare/${entry.slug}` },
  ]),
  buildFaqSchema(entry.faq),
]
---

<Layout
  locale={locale}
  title={entry.title}
  description={entry.description}
  ogDescription={entry.description}
  localized={false}
  jsonLd={jsonLd}
>
  <TheNavbar locale={locale} t={dict.navbar} />

  <main class="mx-auto max-w-7xl px-6 py-16 lg:px-8 lg:py-24">
    <a
      href="/compare"
      class="mb-10 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5M12 5l-7 7 7 7" />
      </svg>
      Back to comparisons
    </a>

    <header class="max-w-4xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">{entry.keyword}</p>
      <h1 class="font-display text-4xl font-bold tracking-tight lg:text-6xl">
        Veerify vs {entry.competitor}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
        {entry.intro}
      </p>
    </header>

    <section class="mt-14 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <div class="rounded-3xl border border-primary/20 bg-primary/5 p-8">
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">Choose Veerify if</p>
        <p class="text-base leading-relaxed text-foreground">{entry.veerifyFit}</p>
      </div>
      <div class="rounded-3xl border border-border/60 bg-card p-8">
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">Choose {entry.competitor} if</p>
        <p class="text-base leading-relaxed text-foreground">{entry.competitorFit}</p>
      </div>
    </section>

    <section class="mt-16">
      <div class="max-w-2xl">
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">Why teams switch</p>
        <h2 class="font-display text-3xl font-bold tracking-tight lg:text-4xl">
          Why Veerify works as a {entry.competitor} alternative
        </h2>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-5 lg:grid-cols-3">
        {entry.reasons.map((reason) => (
          <div class="rounded-2xl border border-border/60 bg-card p-6">
            <h3 class="text-lg font-semibold tracking-tight">{reason.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{reason.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-16 rounded-3xl border border-border/60 bg-card p-8 lg:p-10">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">FAQ</p>
      <h2 class="font-display text-3xl font-bold tracking-tight">Common questions</h2>
      <div class="mt-8 grid grid-cols-1 gap-5">
        {entry.faq.map((item) => (
          <div class="rounded-2xl border border-border/60 bg-background/60 p-6">
            <h3 class="text-lg font-semibold tracking-tight">{item.question}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{item.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-16">
      <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">Related comparisons</p>
          <h2 class="font-display text-3xl font-bold tracking-tight">Explore other alternatives</h2>
        </div>

        <a
          href="https://app.veerify.io/get-started"
          class="inline-flex h-11 items-center justify-center rounded-xl bg-primary px-5 text-sm font-semibold text-primary-foreground transition-opacity hover:opacity-90"
        >
          Try Veerify free
        </a>
      </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
        {relatedEntries.map((related) => (
          <a
            href={`/compare/${related.slug}`}
            class="group rounded-2xl border border-border/60 bg-card p-6 transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5"
          >
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-primary">
              {related.keyword}
            </p>
            <h3 class="font-display text-2xl font-bold tracking-tight transition-colors group-hover:text-primary">
              Veerify vs {related.competitor}
            </h3>
          </a>
        ))}
      </div>
    </section>
  </main>

  <TheFooter locale={locale} t={dict.footer} />
</Layout>
