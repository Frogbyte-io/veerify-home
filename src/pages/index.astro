---
import Layout from '../layouts/Layout.astro'
import TheNavbar from '../components/TheNavbar.astro'
import HeroSection from '../components/HeroSection.astro'
import FeaturesSection from '../components/FeaturesSection.astro'
import HowItWorksSection from '../components/HowItWorksSection.astro'
import PricingSection from '../components/PricingSection.astro'
import BenefitsSection from '../components/BenefitsSection.astro'
import CompareSection from '../components/CompareSection.astro'
import CtaSection from '../components/CtaSection.astro'
import TheFooter from '../components/TheFooter.astro'
import { defaultLocale, getDictionary } from '../i18n/site'
import { buildOrganizationSchema, buildSoftwareApplicationSchema } from '../lib/seo'

const locale = defaultLocale
const dict = getDictionary(locale)
const homepageJsonLd = [buildOrganizationSchema(), buildSoftwareApplicationSchema()]
---

<Layout locale={locale} jsonLd={homepageJsonLd}>
  <TheNavbar locale={locale} t={dict.navbar} />
  <HeroSection locale={locale} t={dict.hero} mockup={dict.productMockup} />
  <FeaturesSection t={dict.features} />
  <HowItWorksSection t={dict.howItWorks} />
  <PricingSection t={dict.pricing} />
  <BenefitsSection t={dict.benefits} />
  <CompareSection />
  <CtaSection t={dict.cta} />
  <TheFooter locale={locale} t={dict.footer} />
</Layout>
