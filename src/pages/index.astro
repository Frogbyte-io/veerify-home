<html>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        var lang = navigator.language || ''
        var isNorwegian = /^(nb|nn|no)\b/i.test(lang)
        window.location.replace(isNorwegian ? '/no' : '/en')
      })()
    </script>
  </head>
  <body></body>
</html>
